JWT_SECRET=replace-with-long-random-secret

AUTH_GRPC_ADDR=:50051
AUTH_USER_SERVICE_GRPC_ADDR=:50052
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=168h

USER_GRPC_ADDR=:50052
